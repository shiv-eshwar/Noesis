# Copy these into .env.local (Next.js loads .env.local for local dev).
# LLM — either key is enough (Anthropic preferred when both are set)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional model overrides
# ANTHROPIC_MODEL=claude-sonnet-4-5
# OPENAI_MODEL=gpt-4o

# Supabase (journey persistence + optional email magic link — Phases 3–4)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — never expose to the browser
# SUPABASE_SERVICE_ROLE_KEY=
# Auth redirects: allow http://localhost:3000 and your Vercel URL in Supabase Auth settings
